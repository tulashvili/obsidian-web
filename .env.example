# Скопируйте в .env и заполните. Мастер-пароль НЕ хранится здесь —
# он вводится в веб-интерфейсе при каждом старте и живёт только в RAM.

# URL git-репозитория (источник истины).
#   HTTPS: https://github.com/user/my-vault.git  (+ токен ниже для приватного)
#   SSH:   git@github.com:user/my-vault.git       (+ OSA_GIT_SSH_KEY)
OSA_REPO_URL=

# Ветка по умолчанию.
OSA_REPO_BRANCH=main

# Для приватного HTTPS-репозитория — персональный токен доступа.
OSA_GIT_USERNAME=git
OSA_GIT_TOKEN=

# Лимит RAM-кэша расшифрованных assets в байтах (по умолчанию 256 МиБ).
OSA_ASSET_CACHE=268435456
